# --- Terraform ---

# State files: record what Terraform built and OFTEN CONTAIN SECRETS in plain
# text. Never commit. They also cause conflicts if shared carelessly.
*.tfstate
*.tfstate.*

# Crash log Terraform writes if it panics.
crash.log
crash.*.log

# Variable files: frequently hold secrets / environment-specific values.
# (If you ever want to commit a SAMPLE, name it terraform.tfvars.example and
#  force-add it — that file is intentionally allowed below.)
*.tfvars
*.tfvars.json
!*.tfvars.example

# The .terraform directory: provider plugin cache + modules. Large,
# machine-specific, and regenerated by `terraform init`. No need to track.
.terraform/
.terraform.lock.hcl.bak

# Override files: meant for local-only experimentation.
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Saved plan output files (may contain sensitive data).
*.tfplan

# --- AWS / secrets (belt-and-suspenders) ---
# Real credentials live in C:\Users\User\.aws\ (outside this project), but block
# any stray copies just in case.
.aws/
*.pem
.env
.env.*

# --- OS / editor noise ---
.DS_Store
Thumbs.db
.vscode/
.idea/

# NOTE: .terraform.lock.hcl is intentionally NOT ignored — we DO commit it so
# provider versions are pinned and reproducible across machines.
